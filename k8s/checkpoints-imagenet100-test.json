{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "ckpt-imagenet100-test",
    "namespace": "b-ahsan3919"
  },
  "spec": {
    "parallelism": 1,
    "ttlSecondsAfterFinished": 86400,
    "template": {
      "spec": {
        "securityContext": {
          "runAsUser": 1051,
          "runAsGroup": 1051
        },
        "containers": [
          {
            "name": "checkpoints-imagenet100-test",
            "image": "abrainone/ai-linux:cu12.6.3-latest",
            "imagePullPolicy": "Always",
            "command": ["/bin/bash", "-c"],
            "args": [
              "set -euo pipefail; export HOME=/shared/ssd/home/b-ahsan3919; export HF_HOME=/shared/ssd/home/b-ahsan3919/.cache/huggingface; export PYTHONUNBUFFERED=1; export GIT_CONFIG_NOSYSTEM=1; export GIT_CONFIG_GLOBAL=/dev/null; cd /shared/ssd/home/b-ahsan3919/nn-dataset; export PYTHONPATH=/shared/ssd/home/b-ahsan3919/nn-dataset:$PYTHONPATH; python3 -m pip install --user -e . -q 2>&1 | tail -5; python3 -c \"import torch; print('CUDA:', torch.cuda.is_available())\"; python3 util/py/checkpoints_to_hugging_face.py --dataset imagenet100 --epoch-train-max 1 --model ComplexNet --dry-run"
            ],
            "resources": {
              "requests": {
                "nvidia.com/gpu": 0,
                "cpu": 2,
                "memory": "8Gi"
              },
              "limits": {
                "cpu": 8,
                "memory": "16Gi"
              }
            },
            "volumeMounts": [
              { "mountPath": "/dev/shm", "name": "shm" },
              { "mountPath": "/shared/ssd", "name": "shared-ssd" },
              { "mountPath": "/shared/local/data/b-ahsan3919", "name": "local-data" }
            ]
          }
        ],
        "restartPolicy": "Never",
        "volumes": [
          {
            "name": "shm",
            "emptyDir": { "medium": "Memory", "sizeLimit": "4Gi" }
          },
          {
            "name": "shared-ssd",
            "hostPath": { "path": "/shared/ssd", "type": "Directory" }
          },
          {
            "name": "local-data",
            "hostPath": { "path": "/shared/local/data/b-ahsan3919", "type": "DirectoryOrCreate" }
          }
        ]
      }
    },
    "backoffLimit": 1
  }
}
