{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "b-a-kumar-train-final",
    "namespace": "b-a-kumar"
  },
  "spec": {
    "parallelism": 1,
    "ttlSecondsAfterFinished": 86400,
    "template": {
      "spec": {
        "securityContext": {
          "runAsUser": 1051,
          "runAsGroup": 1051
        },
        "containers": [
          {
            "name": "train-final",
            "image": "abrainone/ai-linux:cu12.6.3-latest",
            "imagePullPolicy": "Always",
            "command": ["/bin/bash", "-c"],
            "args": [
              "set -e; cd /shared/ssd/home/b-a-kumar/nn-dataset; git pull origin age-estimation-model; pip install -e . 2>&1 | tail -5; echo '--- GPU Check ---'; python -c \"import torch; print(f'CUDA: {torch.cuda.is_available()}, Device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else CPU}')\" ; echo '--- Starting Final Training ---'; python train_final.py; echo '--- Done ---'; python check_results.py"
            ],
            "resources": {
              "requests": {
                "nvidia.com/gpu": 1,
                "cpu": 8,
                "memory": "30Gi"
              },
              "limits": {
                "nvidia.com/gpu": 1,
                "cpu": 64,
                "memory": "120Gi"
              }
            },
            "volumeMounts": [
              { "mountPath": "/dev/shm", "name": "shm" },
              { "mountPath": "/shared/ssd", "name": "shared-ssd" },
              { "mountPath": "/shared/local/data/b-a-kumar", "name": "local-data" }
            ]
          }
        ],
        "restartPolicy": "Never",
        "volumes": [
          {
            "name": "shm",
            "emptyDir": { "medium": "Memory", "sizeLimit": "16Gi" }
          },
          {
            "name": "shared-ssd",
            "hostPath": { "path": "/shared/ssd", "type": "Directory" }
          },
          {
            "name": "local-data",
            "hostPath": { "path": "/shared/local/data/b-a-kumar", "type": "DirectoryOrCreate" }
          }
        ]
      }
    },
    "backoffLimit": 1
  }
}
