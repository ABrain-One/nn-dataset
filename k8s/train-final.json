{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "b-a-kumar-train-final",
    "namespace": "b-a-kumar"
  },
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "train-final",
            "image": "abrainone/ai-linux:latest",
            "command": ["/bin/bash", "-c"],
            "args": [
              "set -e; cd /shared/ssd/home/b-a-kumar/nn-dataset; git pull origin age-estimation-model; pip install -e . 2>&1 | tail -5; echo '--- GPU Check ---'; python -c \"import torch; print(f'CUDA: {torch.cuda.is_available()}, Device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else \\\"CPU\\\"}')\" ; echo '--- Starting Final Training ---'; python train_final.py; echo '--- Done ---'; python check_results.py"
            ],
            "resources": {
              "requests": {
                "cpu": "4",
                "memory": "16Gi",
                "nvidia.com/gpu": "1"
              },
              "limits": {
                "cpu": "4",
                "memory": "16Gi",
                "nvidia.com/gpu": "1"
              }
            },
            "volumeMounts": [
              { "name": "shared-ssd", "mountPath": "/shared/ssd" },
              { "name": "shared-hdd", "mountPath": "/shared/hdd" }
            ]
          }
        ],
        "securityContext": {
          "runAsUser": 1051,
          "runAsGroup": 1051
        },
        "restartPolicy": "Never",
        "volumes": [
          { "name": "shared-ssd", "persistentVolumeClaim": { "claimName": "shared-ssd" } },
          { "name": "shared-hdd", "persistentVolumeClaim": { "claimName": "shared-hdd" } }
        ]
      }
    },
    "backoffLimit": 1
  }
}
