.*/

# Automatically created folders:
/db/
/data/
/venv/

# Heavy checkpoints and weights directories in out:
/out/ckpt/
/out/llm/
/out/tokenizer/
/out/final_training/

# Dynamically created SQLite database files:
*.db

# Python cache
__pycache__/
*.pyc

# Logs
*.log
*log.txt

# local build artifacts
*.egg-info/

# Heavy Data
_work/data/
_work/temp/

# Results - Ignore large models but keep JSON progress
_work/stats/*.tflite
_work/stats/tmp_run_*/
_work/stats/img-classification*/

# Allow JSON files
!_work/stats/*.json

# Local evidence outputs (do not commit)
diff_summary.md
test_output_local_*.txt


# Local automation scripts (not part of project)
AutoTrainAll.py
DeepTrainSOTA.py
gpu_hold.py
gpu_hold.log
autoscheduler.log
deeptrain.log
scratch/
